/*
================================================================================
    rna-dexamethasone Nextflow config file
================================================================================
*/

// ─── Global default parameters ────────────────────────────────────────────────

params {

    check_max = { obj, type ->
        if (type == 'memory') {
            try {
                if (obj.compareTo(params.max_memory as nextflow.util.MemoryUnit) == 1)
                    return params.max_memory as nextflow.util.MemoryUnit
                else
                    return obj
            } catch (all) {
                println "WARNING: max_memory '${params.max_memory}' is not valid."
                return obj
            }
        } else if (type == 'time') {
            try {
                if (obj.compareTo(params.max_time as nextflow.util.Duration) == 1)
                    return params.max_time as nextflow.util.Duration
                else
                    return obj
            } catch (all) {
                println "WARNING: max_time '${params.max_time}' is not valid."
                return obj
            }
        } else if (type == 'cpus') {
            try {
                return Math.min(obj, params.max_cpus as int)
            } catch (all) {
                println "WARNING: max_cpus '${params.max_cpus}' is not valid."
                return obj
            }
        }
    }

    trace_timestamp = new java.util.Date().format('yyyy-MM-dd_HH-mm-ss')

    // ── Input/Output ─────────────────────────────────────────
    samplesheet    = "${projectDir}/assets/samplesheet.csv"
    metadata       = "${projectDir}/assets/metadata.csv"
    outdir         = "results"

    // ── Reference genome ─────────────────────────────────────
    genome         = "GRCh38"
    star_index     = null
    gtf            = null
    star_genome_sa_indexnbases = 14

    // ── Analysis thresholds ───────────────────────────────────
    pvalue_cutoff  = 0.05
    fdr_cutoff     = 0.05
    lfc_threshold  = 1.0
    organism       = "human"

    // ── Tool-specific parameters ──────────────────────────────
    // fastp
    fastp_min_length    = 30
    fastp_quality       = 20
    fastp_threads       = 4

    // STAR
    star_threads        = 4
    star_out_sam_type   = "BAM SortedByCoordinate"
    star_two_pass       = false

    // featureCounts
    fc_threads          = 4
    fc_feature_type     = "exon"
    fc_group_attribute  = "gene_id"

    // DESeq2
    deseq2_min_count    = 10
    deseq2_lfc_shrink   = true

    // ── Reporting ─────────────────────────────────────────────
    report_title        = "RNA-seq Analysis: Dexamethasone Effects on Human Airway Smooth Muscle Cells"

    // ── Resource limits ───────────────────────────────────────
    max_cpus   = 16
    max_memory = '12.GB'
    max_time   = '240.h'

    // ── Pipeline metadata ─────────────────────────────────────
    help       = false

    version    = false
}

// ─── Docker configuration (Global Default) ───────────────────────────────────
// NOTE: Add any extra bind mounts your system needs via the docker profile
// runOptions below, or pass them via NXF_DOCKER_OPTS environment variable.
docker {
    enabled         = true
    userEmulation   = true
    runOptions      = '-u $(id -u):$(id -g)'
}

// ─── Process-level defaults ────────────────────────────────────────────────────

process {
    errorStrategy = { task.exitStatus in [143, 137, 104, 134, 139] ? 'retry' : 'finish' }
    maxRetries    = 2
    maxErrors     = '-1'
    container     = 'rna-dexamethasone:1.0.0'
    stageInMode   = 'copy'

    // Default
    cpus   = 2
    memory = '6.GB'
    time   = '4.h'

    // ── Resource labels ──────────────────────────────────────
    withLabel: 'process_single' {
        cpus   = 1
        memory = '2.GB'
        time   = '2.h'
    }

    withLabel: 'process_low' {
        cpus   = 2
        memory = '4.GB'
        time   = '4.h'
    }

    withLabel: 'process_medium' {
        cpus   = 4
        memory = '8.GB'
        time   = '8.h'
    }

    withLabel: 'process_high' {
        cpus   = 4
        memory = '10.GB'
        time   = '12.h'
    }

    withLabel: 'process_r' {
        cpus   = 2
        memory = '8.GB'
        time   = '4.h'
    }

    // ── Per-module resource overrides ─────────────────────────
    withName: 'STAR_ALIGN' {
        cpus   = { params.check_max(params.star_threads,     'cpus'  ) }
        memory = { params.check_max(64.GB * task.attempt,    'memory') }
        time   = { params.check_max(12.h  * task.attempt,    'time'  ) }
        ext.args = '--outTmpDir /tmp/star_tmp'
    }

    withName: 'FEATURECOUNTS' {
        cpus   = { params.check_max(params.fc_threads,       'cpus'  ) }
        memory = { params.check_max(8.GB  * task.attempt,    'memory') }
        container = null
    }

    withName: 'DESEQ2' {
        cpus   = 4
        memory = { params.check_max(16.GB * task.attempt,    'memory') }
        time   = { params.check_max(2.h   * task.attempt,    'time'  ) }
    }

    withName: 'MULTIQC' {
        cpus   = 2
        memory = { params.check_max(4.GB  * task.attempt,    'memory') }
    }
}

// ─── Execution profiles ────────────────────────────────────────────────────────

profiles {

    // ── Local execution ──────────────────────────────────────
    local {
        process.executor = 'local'
    }

    // ── Docker profile ───────────────────────────────────────
    // WSL2 users: add '-v /mnt/d:/mnt/d' (or your data drive) to runOptions
    docker {
        docker.enabled         = true
        docker.userEmulation   = true
        docker.runOptions      = '-u $(id -u):$(id -g)'
        singularity.enabled    = false
        conda.enabled          = false
        process.container      = 'rna-dexamethasone:1.0.0'
    }

    // ── Singularity profile ──────────────────────────────────
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        docker.enabled         = false
        conda.enabled          = false
        process.container      = 'docker://ghcr.io/yourname/rna-dexamethasone:1.0.0'
    }

    // ── Conda profile ────────────────────────────────────────
    conda {
        conda.enabled          = true
        conda.useMamba         = true
        docker.enabled         = false
        singularity.enabled    = false

        process {
            withName: 'FASTQC|FASTP|MULTIQC' {
                conda = "${projectDir}/conf/envs/qc.yml"
            }
            withName: 'STAR_ALIGN|BAM_QC|FEATURECOUNTS' {
                conda = "${projectDir}/conf/envs/align.yml"
            }
            withLabel: 'process_r' {
                conda = "${projectDir}/conf/envs/r_analysis.yml"
            }
        }
    }

    // ── SLURM HPC profile ────────────────────────────────────
    slurm {
        process.executor    = 'slurm'
        process.queue       = 'normal'
        process.clusterOptions = '--account=rnaseq_project'
        executor {
            queueSize       = 50
            submitRateLimit = '10/1min'
        }
    }

    // ── Test profile (small dataset) ─────────────────────────
    test {
        params {
            samplesheet   = "${projectDir}/assets/test_samplesheet.csv"
            metadata      = "${projectDir}/assets/test_metadata.csv"
            star_index    = "${projectDir}/test_data/star_index_chr1"
            gtf           = "${projectDir}/test_data/chr1.gtf"
            max_cpus      = 2
            max_memory    = '4.GB'
            max_time      = '30.m'
        }
    }
}

// ─── Pipeline reporting ────────────────────────────────────────────────────────

timeline {
    enabled = true
    overwrite = true
    file    = "${params.outdir}/pipeline_info/execution_timeline_${params.trace_timestamp}.html"
}

// Limit local execution queue size to 1 to prevent WSL OOM crashes
executor {
    queueSize = 1
}


report {
    enabled = true
    overwrite = true
    file    = "${params.outdir}/pipeline_info/execution_report_${params.trace_timestamp}.html"
}

trace {
    enabled = true
    overwrite = true
    file    = "${params.outdir}/pipeline_info/execution_trace_${params.trace_timestamp}.txt"
    fields  = 'task_id,hash,name,status,exit,realtime,cpus,peak_rss,peak_vmem,rchar,wchar'
}

dag {
    enabled = true
    overwrite = true
    file    = "${params.outdir}/pipeline_info/pipeline_dag_${params.trace_timestamp}.svg"
}

// ─── Manifest ─────────────────────────────────────────────────────────────────

manifest {
    name            = 'rna-dexamethasone'
    author          = 'Bioinformatics Pipeline'
    homePage        = 'https://github.com/YOUR_USERNAME/rna-dexamethasone'
    description     = 'RNA-seq pipeline: dexamethasone effects on airway smooth muscle cells (GSE52778)'
    mainScript      = 'main.nf'
    nextflowVersion = '>=23.04.0'
    version         = '1.0.0'
}

}

